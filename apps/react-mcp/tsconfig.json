{
  "extends": "@blakeui/config/tsconfig/cloudflare-worker.json",
  "compilerOptions": {
    "lib": ["ESNext"],
    "baseUrl": ".",
    "paths": {
      "~/*": ["./src/*"]
    }
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx",
    "scripts/**/*.ts",
    "lib/**/*.ts",
    "vitest.config.ts",
    "package.json"
  ],
  "exclude": ["node_modules", "dist", "mastra", ".mastra"]
}
